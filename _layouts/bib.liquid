---
---
<div class="row">
  {% if site.enable_publication_thumbnails %}
    <div class="col col-sm-2 abbr">
      {%- if entry.abbr -%}
        {%- if site.data.venues[entry.abbr] -%}
          {% assign venue_style = null %}
          {% if site.data.venues[entry.abbr].color != blank %}
            {% assign venue_style = site.data.venues[entry.abbr].color | prepend: 'style="background-color:' | append: '"' %}
          {%- endif -%}
          <abbr
            class="badge rounded w-100"
            {% if venue_style %}
              {{ venue_style }}
            {% endif -%}
          >
            {% if site.data.venues[entry.abbr].url %}
              <a href="{{ site.data.venues[entry.abbr].url }}">{{ entry.abbr }}</a>
            {% else %}
              <div>{{- entry.abbr -}}</div>
            {% endif %}
          </abbr>
        {% else %}
          <abbr class="badge rounded w-100">{{ entry.abbr }}</abbr>
        {% endif %}
      {% endif %}
      {% if entry.preview %}
        {% if entry.preview contains '://' %}
          <img class="preview z-depth-1 rounded" src="{{ entry.preview }}">
        {% else %}
          {% assign entry_path = entry.preview | prepend: '/assets/img/publication_preview/' %}
          {%
            include figure.liquid
            loading="eager"
            path=entry_path
            sizes = "200px"
            class="preview z-depth-1 rounded"
            zoomable=true
            avoid_scaling=true
            alt=entry.preview
          %}
        {% endif %}
      {% endif %}
    </div>
  {% endif %}

  <!-- Entry bib key -->
  <div id="{{ entry.key }}" class="{% if site.enable_publication_thumbnails %}col-sm-8{% else %}col-sm-10{% endif %}">
    <!-- Title -->
    <div class="title">{{ entry.title }}</div>
    <!-- Author -->
    <div class="author">
      {% assign author_array_size = entry.author_array | size %}

      {% assign author_array_limit = author_array_size %}
      {% if site.max_author_limit and author_array_size > site.max_author_limit %}
        {% assign author_array_limit = site.max_author_limit %}
      {% endif %}

      {%- for author in entry.author_array limit: author_array_limit -%}
        {% assign author_is_self = false %}
        {%- assign author_last_name = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' -%}
        {%- assign author_last_html = author.last | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' -%}
        {% if site.scholar.last_name contains author_last_name %}
          {% if site.scholar.first_name contains author.first %}
            {% assign author_is_self = true %}
          {% endif %}
        {%- endif -%}
        {% assign coauthor_url = null %}
        {%- assign clean_last_name = author_last_name | downcase | remove_accents -%}
        {% if site.data.coauthors[clean_last_name] %}
          {%- for coauthor in site.data.coauthors[clean_last_name] -%}
            {% if coauthor.firstname contains author.first %}
              {%- assign coauthor_url = coauthor.url -%}
              {% break %}
            {%- endif -%}
          {% endfor %}
        {%- endif -%}

        {%- if forloop.length > 1 -%}
          {% if forloop.first == false -%}
            {%- if forloop.length > 2 %}, {% elsif forloop.length == 2 %}  {% endif %}
          {%- endif %}
          {%- if forloop.last and author_array_limit == author_array_size %}and {% endif -%}
        {% endif %}
        {%- if author_is_self -%}
          <em class="self-author">
            {{- author.first }}
            {{ author_last_html -}}
          </em>
        {%- else -%}
          {%- if coauthor_url -%}
            <a href="{{ coauthor_url }}">
              {{- author.first }}
              {{ author_last_html -}}
            </a>
          {%- else -%}
            {{- author.first }}
            {{ author_last_html -}}
          {% endif %}
        {%- endif -%}
      {% endfor %}
      {%- assign more_authors = author_array_size | minus: author_array_limit -%}

      {%- assign more_authors_hide = more_authors | append: ' more author' -%}
      {% if more_authors > 0 %}
        {%- if more_authors > 1 -%}
          {% assign more_authors_hide = more_authors_hide | append: 's' %}
        {%- endif -%}
        {% assign more_authors_show = '' %}
        {%- for author in entry.author_array offset: author_array_limit -%}
          {% assign more_authors_show = more_authors_show | append: author.first | append: ' ' | append: author.last %}
          {% unless forloop.last %}
            {% assign more_authors_show = more_authors_show | append: ', ' %}
          {% endunless %}
        {%- endfor -%}
        {%- assign more_authors_show = more_authors_show | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' -%}
        , and
        <span
          class="more-authors"
          title="click to view {{ more_authors_hide }}"
          onclick="
              var element = $(this);
              element.attr('title', '');
              var more_authors_text = element.text() == '{{ more_authors_hide }}' ? '{{ more_authors_show }}' : '{{ more_authors_hide }}';
              var cursorPosition = 0;
              var textAdder = setInterval(function(){
                element.html(more_authors_text.substring(0, cursorPosition + 1));
                if (++cursorPosition == more_authors_text.length){
                  clearInterval(textAdder);
                }
            }, '{{ site.more_authors_animation_delay }}');
          "
        >
          {{- more_authors_hide -}}
        </span>
      {% endif %}
      {% if entry.annotation %}
        <i
          class="fa-solid fa-circle-info ml-1"
          data-toggle="popover"
          data-placement="top"
          data-html="true"
          data-content="{{ entry.annotation | escape }}"
        >
        </i>
      {% endif %}
    </div>

    <!-- Journal/Book title and date -->
    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}
    {% if entry.type == 'article' %}
      {% capture entrytype %}<em>{{ entry.journal }}</em>{% endcapture %}
    {% elsif proceedings contains entry.type %}
      {% capture entrytype %}<em>In {{ entry.booktitle }}</em>{% endcapture %}
    {% elsif thesis contains entry.type %}
      {% capture entrytype %}<em>{{ entry.school }}</em>{% endcapture %}
    {% else %}
      {% capture entrytype %}{% endcapture %}
    {% endif %}
    {% assign entrymonth = '' %}
    {% if entry.month %}
      {% assign m = entry.month | downcase | remove: '.' %}
      {% case m %}
        {% when 'jan' or 'january' %}{% assign month_display = 'Jan.' %}
        {% when 'feb' or 'february' %}{% assign month_display = 'Feb.' %}
        {% when 'mar' or 'march' %}{% assign month_display = 'Mar.' %}
        {% when 'apr' or 'april' %}{% assign month_display = 'Apr.' %}
        {% when 'may' %}{% assign month_display = 'May' %}
        {% when 'jun' or 'june' %}{% assign month_display = 'Jun.' %}
        {% when 'jul' or 'july' %}{% assign month_display = 'Jul.' %}
        {% when 'aug' or 'august' %}{% assign month_display = 'Aug.' %}
        {% when 'sep' or 'september' %}{% assign month_display = 'Sep.' %}
        {% when 'oct' or 'october' %}{% assign month_display = 'Oct.' %}
        {% when 'nov' or 'november' %}{% assign month_display = 'Nov.' %}
        {% when 'dec' or 'december' %}{% assign month_display = 'Dec.' %}
        {% else %}{% assign month_display = entry.month %}
      {% endcase %}
      {% capture entrymonth %}{{ " " }}{{ month_display }}{% endcapture %}
    {% endif %}
    {% assign entryyear = '' %}
    {% if entry.year %}
      {% capture entryyear %}{{ " " }}{{ entry.year }}{% endcapture %}
    {% endif %}
    {% if entry.location %}
      {% capture entrytype %}{{ entrytype }}{{ ", " }}{{ entry.location }}{% endcapture %}
    {% endif -%}
    {% if entry.additional_info %}
      {% capture entrytype %}{{ entrytype }}{{ entry.additional_info | markdownify | remove: '<p>' | remove: '</p>' }}{% endcapture %}
    {% endif %}
    {% capture hook_exists %}{% file_exists _includes/hook/bib.liquid %}{% endcapture %}
    {% if hook_exists == 'true' %}
      {% include hook/bib.liquid %}
    {% endif %}
    {% assign entrytype_text = entrytype | strip_html | strip %}
    {% capture periodical %}{{ entrytype }}{% if entrytype_text != "" and entryyear != "" %}, {% endif %}{{ entrymonth }}{{ entryyear }}{% endcapture %}
    {% assign periodical_clean = periodical | strip %}
    {% if periodical_clean != "" %}
      <div class="periodical">
        {{ periodical_clean }}
      </div>
    {% endif %}
    {% assign note_clean = entry.note | strip %}
    {% if note_clean != "" %}
      <div class="periodical">
        {{ note_clean }}
      </div>
    {% endif %}

    <!-- Links/Buttons -->
    <div class="links">
      {% unless entry.keywords contains 'dom_conf' or entry.keywords contains 'patent' %}
        <a class="abstract btn btn-sm z-depth-0" role="button">Abstract</a>
      {% endunless %}
      {% unless entry.keywords contains 'dom_conf' or entry.keywords contains 'patent' %}
        {% if entry.paper %}
          <a href="{{ entry.paper }}" class="btn btn-sm z-depth-0" role="button" target="_blank" rel="noopener noreferrer">Paper</a>
        {% else %}
          {% assign paper_search = entry.title | url_encode %}
          <a href="https://scholar.google.com/scholar?q={{ paper_search }}" class="btn btn-sm z-depth-0" role="button" target="_blank" rel="noopener noreferrer">Paper</a>
        {% endif %}
        {% if entry.google_scholar_id %}
          {% assign citation_count = 0 %}
          {% assign scholar_id_key = site.scholar_userid | append: ':' | append: entry.google_scholar_id %}
          {% if site.data.citations.papers[scholar_id_key] %}
            {% assign citation_count = site.data.citations.papers[scholar_id_key].citations %}
          {% elsif site.data.citations.papers[entry.google_scholar_id] %}
            {% assign citation_count = site.data.citations.papers[entry.google_scholar_id].citations %}
          {% else %}
            {% for paper in site.data.citations.papers %}
              {% assign paper_key = paper[0] %}
              {% if paper_key contains entry.google_scholar_id %}
                {% assign citation_count = paper[1].citations %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}
          <span class="cite-count"><i class="ai ai-google-scholar"></i>{{ citation_count }} citations</span>
        {% endif %}
        {% unless entry.keywords contains 'submitted' %}
          {% assign if_text = '' %}
          {% case entry.abbr %}
            {% when 'TWC' %}{% assign if_text = 'IF 10.7, JCR Top 3.7%' %}
            {% when 'TCOM' %}{% assign if_text = 'IF 8.3, JCR Top 7.2%' %}
            {% when 'IoT-J' %}{% assign if_text = 'IF 8.9, JCR Top 4.1%' %}
            {% when 'TNNLS' %}{% assign if_text = 'IF 8.9, JCR Top 4.2%' %}
            {% when 'TCCN' %}{% assign if_text = 'IF 7.0, JCR Top 13.7%' %}
          {% endcase %}
          {% if if_text != '' %}
            <span class="impact-factor"><i class="fa-solid fa-chart-line"></i>{{ if_text }}</span>
          {% endif %}
        {% endunless %}
      {% endunless %}
      {% if entry.arxiv %}
        <a href="http://arxiv.org/abs/{{ entry.arxiv }}" class="btn btn-sm z-depth-0" role="button">arXiv</a>
      {% endif %}
      {% if entry.hal %}
        <a href="https://hal.science/{{ entry.hal }}" class="btn btn-sm z-depth-0" role="button">HAL</a>
      {% endif %}
      {% if entry.bibtex_show %}
        <a class="bibtex btn btn-sm z-depth-0" role="button">Bib</a>
      {% endif %}
      {% if entry.html %}
        {% if entry.html contains '://' %}
          <a href="{{ entry.html }}" class="btn btn-sm z-depth-0" role="button">HTML</a>
        {% else %}
          <a href="{{ entry.html | prepend: '/assets/html/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">HTML</a>
        {% endif %}
      {% endif %}
      {% if entry.pdf %}
        {% if entry.pdf contains '://' %}
          <a href="{{ entry.pdf }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
        {% else %}
          <a href="{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
        {% endif %}
      {% endif %}
      {% if entry.supp %}
        {% if entry.supp contains '://' %}
          <a href="{{ entry.supp }}" class="btn btn-sm z-depth-0" role="button">Supp</a>
        {% else %}
          <a href="{{ entry.supp | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">Supp</a>
        {% endif %}
      {% endif %}
      {% if entry.video and site.enable_video_embedding %}
        <a class="abstract btn btn-sm z-depth-0" role="button">Video</a>
      {% elsif entry.video %}
        <a href="{{ entry.video }}" class="btn btn-sm z-depth-0" role="button">Video</a>
      {% endif %}
      {% if entry.blog %}
        <a href="{{ entry.blog }}" class="btn btn-sm z-depth-0" role="button">Blog</a>
      {% endif %}
      {% if entry.code %}
        <a href="{{ entry.code }}" class="btn btn-sm z-depth-0" role="button">Code</a>
      {% endif %}
      {% if entry.poster %}
        {% if entry.poster contains '://' %}
          <a href="{{ entry.poster }}" class="btn btn-sm z-depth-0" role="button">Poster</a>
        {% else %}
          <a href="{{ entry.poster | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">Poster</a>
        {% endif %}
      {% endif %}
      {% if entry.slides %}
        {% if entry.slides contains '://' %}
          <a href="{{ entry.slides }}" class="btn btn-sm z-depth-0" role="button">Slides</a>
        {% else %}
          <a href="{{ entry.slides | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">Slides</a>
        {% endif %}
      {% endif %}
      {% if entry.website %}
        <a href="{{ entry.website }}" class="btn btn-sm z-depth-0" role="button">Website</a>
      {% endif %}
      {% if entry.award %}
        <a class="award btn btn-sm z-depth-0" role="button"><i class="fa-solid fa-trophy"></i>{%- if entry.award_name %}{{ entry.award_name }}{% else %}Awarded{% endif -%}</a>
      {% endif %}
    </div>
    {% if site.enable_publication_badges %}
      {% assign entry_has_altmetric_badge = false %}
      {% if entry.altmetric and entry.altmetric != 'false' %}
        {% assign entry_has_altmetric_badge = true %}
      {% endif %}

      {% assign entry_has_dimensions_badge = false %}
      {% if entry.dimensions and entry.dimensions != 'false' %}
        {% assign entry_has_dimensions_badge = true %}
      {% endif %}

      {% assign entry_has_google_scholar_badge = false %}
      {% if entry.google_scholar_id %}
        {% assign entry_has_google_scholar_badge = true %}
      {% endif %}

      {% assign entry_has_inspirehep_badge = false %}
      {% if entry.inspirehep_id %}
        {% assign entry_has_inspirehep_badge = true %}
      {% endif %}
      {% if entry_has_altmetric_badge or entry_has_dimensions_badge or entry_has_google_scholar_badge or entry_has_inspirehep_badge %}
        <div class="badges">
          {% if site.enable_publication_badges.altmetric and entry_has_altmetric_badge %}
            <span
              class="altmetric-embed"
              data-badge-type="2"
              data-badge-popover="right"
              {% if entry.altmetric != blank and entry.altmetric != 'true' %}
                data-altmetric-id="{{ entry.altmetric }}"
              {% elsif entry.arxiv %}
                data-arxiv-id="{{ entry.arxiv }}"
              {% elsif entry.eprint %}
                data-arxiv-id="{{ entry.eprint }}"
              {% elsif entry.doi %}
                data-doi="{{ entry.doi }}"
              {% elsif entry.pmid %}
                data-pmid="{{ entry.pmid }}"
              {% elsif entry.isbn %}
                data-isbn="{{ entry.isbn }}"
              {% endif %}
            ></span>
          {% endif %}
          {% if site.enable_publication_badges.dimensions and entry_has_dimensions_badge %}
            <span
              class="__dimensions_badge_embed__"
              {% if entry.dimensions != blank and entry.dimensions != 'true' %}
                data-id="{{ entry.dimensions }}"
              {% elsif entry.doi %}
                data-doi="{{ entry.doi }}"
              {% else %}
                data-pmid="{{ entry.pmid }}"
              {% endif %}
              data-style="small_rectangle"
              data-legend="hover-right"
              style="margin-bottom: 3px;"
            ></span>
          {% endif %}
          {% if site.enable_publication_badges.google_scholar and entry_has_google_scholar_badge %}
            <a
              href="https://scholar.google.com/citations?view_op=view_citation&hl=en&user={{ site.data.socials.scholar_userid }}&citation_for_view={{ site.data.socials.scholar_userid }}:{{ entry.google_scholar_id }}"
              aria-label="Google Scholar link"
              role="button"
            >
              {% assign citation_count = 0 %}
              {% assign scholar_id_key = site.scholar_userid | append: ':' | append: entry.google_scholar_id %}
              {% assign publication_key = entry.google_scholar_id %}

              {% if site.data.citations.papers[scholar_id_key] %}
                {% assign citation_count = site.data.citations.papers[scholar_id_key].citations %}
              {% elsif site.data.citations.papers[publication_key] %}
                {% assign citation_count = site.data.citations.papers[publication_key].citations %}
              {% else %}
                {% for paper in site.data.citations.papers %}
                  {% assign paper_key = paper[0] %}
                  {% if paper_key contains entry.google_scholar_id %}
                    {% assign citation_count = paper[1].citations %}
                    {% break %}
                  {% endif %}
                {% endfor %}
              {% endif %}

              <img
                src="https://img.shields.io/badge/scholar-{{ citation_count }}-4285F4?logo=googlescholar&labelColor=beige"
                alt="{{ citation_count }} Google Scholar citations"
              >
            </a>
          {% endif %}
          {% if site.enable_publication_badges.inspirehep and entry_has_inspirehep_badge %}
            <a
              href="https://inspirehep.net/literature/{{ entry.inspirehep_id }}"
              aria-label="Inspirehep link"
              role="button"
            >
              <img
                src="https://img.shields.io/badge/inspire-{% inspirehep_citations entry.inspirehep_id %}-001628?logo=inspire&logoColor=001628&labelColor=beige"
                alt="{% inspirehep_citations entry.inspirehep_id %} InspireHEP citations"
              >
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    {% if entry.award %}
      <!-- Hidden Award block -->
      <div class="award hidden d-print-inline">
        <p>{{ entry.award | markdownify }}</p>
      </div>
    {% endif %}

    {% unless entry.keywords contains 'dom_conf' or entry.keywords contains 'patent' %}
      <!-- Hidden abstract block -->
      <div class="abstract hidden">
        {% if entry.abstract %}
          <p>{{ entry.abstract }}</p>
        {% else %}
          <p><em>Abstract is not yet provided.</em></p>
        {% endif %}
      </div>
    {% endunless %}

    {% if entry.bibtex_show %}
      <!-- Hidden bibtex block -->
      <div class="bibtex hidden">
        {% capture rendered_bibtex %}{{ entry.bibtex | hideCustomBibtex }}{% endcapture %}
        {% assign rendered_bibtex = rendered_bibtex
          | replace: 'month = jan,', 'month = {Jan.},'
          | replace: 'month = feb,', 'month = {Feb.},'
          | replace: 'month = mar,', 'month = {Mar.},'
          | replace: 'month = apr,', 'month = {Apr.},'
          | replace: 'month = may,', 'month = {May},'
          | replace: 'month = jun,', 'month = {Jun.},'
          | replace: 'month = jul,', 'month = {Jul.},'
          | replace: 'month = aug,', 'month = {Aug.},'
          | replace: 'month = sep,', 'month = {Sep.},'
          | replace: 'month = oct,', 'month = {Oct.},'
          | replace: 'month = nov,', 'month = {Nov.},'
          | replace: 'month = dec,', 'month = {Dec.},'
          | replace: 'IEEE Transactions on Wireless Communications', 'IEEE Trans. Wireless Commun.'
          | replace: 'IEEE Transactions on Communications', 'IEEE Trans. Commun.'
          | replace: 'IEEE Communications Letters', 'IEEE Commun. Lett.'
          | replace: 'IEEE Internet of Things Journal', 'IEEE Internet Things J.'
          | replace: 'IEEE Transactions on Neural Networks and Learning Systems', 'IEEE Trans. Neural Netw. Learn. Syst.'
          | replace: 'IEEE Transactions on Cognitive Communications and Networking', 'IEEE Trans. Cogn. Commun. Netw.'
          | replace: 'Electronics Letters', 'Electron. Lett.'
          | replace: 'The Journal of Korean Institute of Communications and Information Sciences', 'J. Korean Inst. Commun. Inf. Sci.'
          | replace: 'title = {Towards Optimal Semantic Communications: Reconsidering the Role of Semantic Feature Channels}', 'title = {{Towards optimal semantic communications: Reconsidering the role of semantic feature channels}}'
          | replace: 'title = {Channel Coding for Unequal Error Protection in Digital Semantic Communication}', 'title = {{Channel coding for unequal error protection in digital semantic communication}}'
          | replace: 'title = {Rate-Adaptive Semantic Communication via Multi-Stage Vector Quantization}', 'title = {{Rate-adaptive semantic communication via multi-stage vector quantization}}'
          | replace: 'title = {Prior-Aware Robust Beam Alignment for Low-SNR Millimeter-Wave Communications}', 'title = {{Prior-aware robust beam alignment for low-SNR millimeter-wave communications}}'
          | replace: 'title = {Importance-Aware Semantic Communication in MIMO-OFDM Systems Using Vision Transformer}', 'title = {{Importance-aware semantic communication in MIMO-OFDM systems using vision transformer}}'
          | replace: 'title = {ESC-MVQ: End-to-End Semantic Communication with Multi-Codebook Vector Quantization}', 'title = {{ESC-MVQ: End-to-end semantic communication with multi-codebook vector quantization}}'
          | replace: 'title = {Blind Training for Channel-Adaptive Digital Semantic Communications}', 'title = {{Blind training for channel-adaptive digital semantic communications}}'
          | replace: 'title = {Deep Learning-Based Modulation and Power Control: A BER Perspective}', 'title = {{Deep learning-based modulation and power control: A BER perspective}}'
          | replace: 'title = {End-to-End Training and Adaptive Transmission for OFDM-Based Semantic Communication}', 'title = {{End-to-end training and adaptive transmission for OFDM-based semantic communication}}'
          | replace: 'title = {Vision Transformer-Based Semantic Communications with Importance-Aware Quantization}', 'title = {{Vision transformer-based semantic communications with importance-aware quantization}}'
          | replace: 'title = {Deep Learning-Assisted Parallel Interference Cancellation for Grant-Free NOMA in Machine-Type Communication}', 'title = {{Deep learning-assisted parallel interference cancellation for grant-free NOMA in machine-type communication}}'
          | replace: 'title = {Communication-Efficient Split Learning via Adaptive Feature-Wise Compression}', 'title = {{Communication-efficient split learning via adaptive feature-wise compression}}'
          | replace: 'title = {Joint Source-Channel Coding for Channel-Adaptive Digital Semantic Communications}', 'title = {{Joint source-channel coding for channel-adaptive digital semantic communications}}'
          | replace: 'title = {Communication-Efficient Federated Learning over Capacity-Limited Wireless Networks}', 'title = {{Communication-efficient federated learning over capacity-limited wireless networks}}'
          | replace: 'title = {{SplitMAC}: Wireless Split Learning over Multiple Access Channels}', 'title = {{SplitMAC: Wireless split learning over multiple access channels}}'
          | replace: 'title = {{FedVQCS}: Federated Learning via Vector Quantized Compressed Sensing}', 'title = {{FedVQCS: Federated learning via vector quantized compressed sensing}}'
          | replace: 'title = {Communication-Efficient Federated Learning via Quantized Compressed Sensing}', 'title = {{Communication-efficient federated learning via quantized compressed sensing}}'
          | replace: 'title = {{C-CNNLoc}: Constrained {CNN} for Robust Indoor Localization with Building Boundary}', 'title = {{C-CNNLoc: Constrained CNN for robust indoor localization with building boundary}}'
          | replace: 'title = {{RB-LoRA}: Rank-Balanced Aggregation for Low-Rank Adaptation with Federated Fine-Tuning}', 'title = {{RB-LoRA: Rank-balanced aggregation for low-rank adaptation with federated fine-tuning}}'
          | replace: 'title = {End-to-End Semantic Communication via Multi-Codebook Vector Quantization}', 'title = {{End-to-end semantic communication via multi-codebook vector quantization}}'
          | replace: 'title = {Vision Transformer-Aided Importance-Aware Quantization for Digital Semantic Communications}', 'title = {{Vision transformer-aided importance-aware quantization for digital semantic communications}}'
          | replace: 'title = {Joint Activity Detection and Channel Estimation in Grant-Free {NOMA} via Deep Learning-Assisted Parallel Interference Cancellation}', 'title = {{Joint activity detection and channel estimation in grant-free NOMA via deep learning-assisted parallel interference cancellation}}'
          | replace: 'title = {Joint Source-Channel Coding for Robust Digital Semantic Communications}', 'title = {{Joint source-channel coding for robust digital semantic communications}}'
          | replace: 'title = {Robust Beam Alignment Using Prior Information for Low-SNR Millimeter-Wave Communications}', 'title = {{Robust beam alignment using prior information for low-SNR millimeter-wave communications}}'
          | replace: 'title = {Vector Quantized Compressed Sensing for Communication-Efficient Federated Learning}', 'title = {{Vector quantized compressed sensing for communication-efficient federated learning}}'
          | replace: 'title = {Quantized Compressed Sensing for Communication-Efficient Federated Learning}', 'title = {{Quantized compressed sensing for communication-efficient federated learning}}'
          | replace: 'title = {A Survey of Deep Learning-Assisted Indoor Localization with {Wi-Fi} Fingerprinting: Current Status and Research Challenges}', 'title = {{A survey of deep learning-assisted indoor localization with Wi-Fi fingerprinting: Current status and research challenges}}'
          | replace: 'title = {Blind Training for Power and Modulation Level Optimization in Digital Semantic Communication}', 'title = {{Blind training for power and modulation level optimization in digital semantic communication}}'
