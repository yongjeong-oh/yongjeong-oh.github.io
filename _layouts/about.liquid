---
layout: default
---
{% if page._styles %}
  <!-- Page-specific style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post about-page">
  <article>
    {% assign about_parts = content | split: '<!-- ABOUT-CV-SPLIT -->' %}

    <!-- Merged top card: photo + bio share a single bordered container. -->
    <div class="card mt-3 p-3 about-bio-card">
      <div class="about-bio-grid">
        {% if page.profile %}
          <aside class="profile about-bio-photo">
            {% if page.profile.image %}
              {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
              {% if page.profile.image_circular %}
                {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
              {% else %}
                {% assign profile_image_class = 'img-fluid z-depth-1
          rounded' %}
              {% endif %}
              {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
          30vw, 95vw"{% endcapture %}
              {%
                include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
                cache_bust=true
              %}
            {% endif %}
            {% if page.profile.more_info %}
              <div class="more-info">{{ page.profile.more_info }}</div>
            {% endif %}
          </aside>
        {% endif %}
        <div class="about-bio-content">{{ about_parts[0] }}</div>
      </div>
    </div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <div class="publications about-news">
        <div class="card mt-3 p-3">
          <div class="news-header">
            <h3 class="card-title font-weight-medium"><i class="fa-solid fa-newspaper section-icon"></i>News</h3>
            <div class="news-actions">
              <a href="{{ '/news/' | relative_url }}" class="news-all-link">View all<i class="fa-solid fa-arrow-right-long"></i></a>
              <button class="news-toggle" type="button" aria-pressed="false" aria-label="Toggle news list">
                <span class="news-toggle-switch"></span>
                <span class="news-toggle-label">Collapsed</span>
              </button>
            </div>
          </div>
          {% include news.liquid limit=true since=2026 %}
        </div>
      </div>
      <script>
        (function () {
          function bindToggle(btnSel, listSel, labelSel) {
            var btn = document.querySelector(btnSel);
            var list = document.querySelector(listSel);
            if (!btn || !list) return;
            var label = btn.querySelector(labelSel);
            btn.addEventListener('click', function () {
              var expanded = btn.classList.toggle('expanded');
              list.classList.toggle('expanded', expanded);
              btn.setAttribute('aria-pressed', expanded ? 'true' : 'false');
              if (label) label.textContent = expanded ? 'Expanded' : 'Collapsed';
            });
          }
          document.addEventListener('DOMContentLoaded', function () {
            bindToggle('.about-news .news-toggle', '.about-news .news-list', '.news-toggle-label');

            // Award rows: click to expand the detail block (image / PDF link).
            document.querySelectorAll('.about-awards .award-item').forEach(function (li) {
              var row = li.querySelector('.award-row');
              if (!row) return;
              row.addEventListener('click', function () {
                li.classList.toggle('expanded');
              });
            });

            // Copy-to-clipboard buttons next to non-link profile fields
            // (e.g. email). Falls back to a hidden textarea when the
            // Clipboard API is unavailable (older browsers, insecure origins).
            document.querySelectorAll('.profile-link-copy').forEach(function (btn) {
              btn.addEventListener('click', function (e) {
                e.preventDefault();
                var text = btn.getAttribute('data-copy');
                if (!text) return;

                function flash() {
                  var icon = btn.querySelector('i');
                  var prevCls = icon ? icon.className : '';
                  btn.classList.add('copied');
                  if (icon) icon.className = 'fa-solid fa-check';
                  setTimeout(function () {
                    btn.classList.remove('copied');
                    if (icon) icon.className = prevCls;
                  }, 1500);
                }

                if (navigator.clipboard && navigator.clipboard.writeText) {
                  navigator.clipboard
                    .writeText(text)
                    .then(flash)
                    .catch(function () {});
                } else {
                  var ta = document.createElement('textarea');
                  ta.value = text;
                  ta.setAttribute('readonly', '');
                  ta.style.position = 'absolute';
                  ta.style.left = '-9999px';
                  document.body.appendChild(ta);
                  ta.select();
                  try {
                    document.execCommand('copy');
                    flash();
                  } catch (err) {}
                  document.body.removeChild(ta);
                }
              });
            });
          });
        })();
      </script>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected publications (compact card grid) -->
    {% if page.selected_papers %}
      <div class="card mt-3 p-3 about-selected">
        <h3 class="card-title font-weight-medium" id="selected-publications">
          <i class="fa-solid fa-book-open section-icon"></i>
          <span class="sel-title-link">Selected Publications</span>
          <a href="{{ '/publications/' | relative_url }}" class="sel-all-link">View all<i class="fa-solid fa-arrow-right-long"></i></a>
        </h3>
        <div class="sel-grid">
          {% bibliography --group_by none --query @*[selected=true]* --template bib_card %}
        </div>
      </div>
    {% endif %}

    {% if about_parts[1] %}
      <div class="about-cv-extra">{{ about_parts[1] }}</div>
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
